{
  "hosting": {
    "public": ".",
    "ignore": [
      ".git/**",
      ".github/**",
      ".firebase/**",
      ".widget-data/**",
      "firebase.json",
      ".firebaserc",
      "*.ps1",
      "*.vbs",
      "*.ico",
      "yapes.ico",
      "reporte_ventas.js",
      "lanzar-yapes.*",
      "setTopmost-yapes.*",
      "crear-acceso-directo.ps1"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/manifest.json",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}
