{
  "hosting": {
    "public": ".",
    "ignore": [
      ".firebase/**",
      ".widget-data/**",
      "firebase.json",
      ".firebaserc",
      "*.ps1",
      "*.vbs",
      "*.ico",
      "yapes.ico"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/manifest.json",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}
